{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test:hud:e2e": "playwright test tests/hud/hud-e2e.spec.ts --reporter=line",
    "test:hud:visual": "playwright test tests/hud/hud-visual.spec.ts --reporter=line",
    "qa:hud": "npm run build && playwright test tests/hud --reporter=line"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.6.3",
    "vite": "^7.0.0",
    "vue-tsc": "^2.1.0"
  }
}
